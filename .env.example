# Jira API configuration
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_api_token

# Report options
JIRA_PROJECT=MYPROJECT
JIRA_START_DATE=2024-01-01
JIRA_END_DATE=2024-01-31

# Optional settings
REPORT_TIMEZONE=UTC
REPORT_OUTPUT_FILE=worklog_report.xlsx
CACHE_FILE=.cache/worklogs_cache.json
USE_CACHE=true
LOG_LEVEL=INFO
